# Local development environment for docker-compose.yml.
#
# Copy this file to ".env" (which is gitignored) and adjust the values.
# These configure the LOCAL Postgres container only. NEVER commit a real .env
# with real credentials (Art. VI.4 — no secrets in the repo).
#
#   cp .env.example .env
#
# The backend reads its actual connection string from .NET user-secrets
# (E0-07), not from this file.

# Database name created on first container start.
POSTGRES_DB=jaarplanner

# Database superuser for local dev. Any value is fine locally.
POSTGRES_USER=jaarplanner

# Local-only password. Replace with anything for your machine; this placeholder
# is intentionally not a real secret. Do NOT reuse a real/shared password.
POSTGRES_PASSWORD=changeme-local-dev

# Host port mapped to the container's 5432. Default 5433 avoids clashing with a
# local Postgres install. Change if 5433 is also taken on your machine.
DB_HOST_PORT=5433
